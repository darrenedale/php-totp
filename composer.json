{
  "name": "citruslab/totp",
  "description": "TOTP generator for PHP",
  "readme": "README.md",
  "keywords": [
    "authentication",
    "totp",
    "2fa"
  ],
  "homepage": "https://github.com/darrenedale/php-totp",
  "minimum-stability": "stable",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Darren Edale",
      "email": "packagist@equit.dev"
    }
  ],
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10",
    "ext-mbstring": "*",
    "equit/xray": "dev-main",
    "citruslab/mokkd": "0.0.*"
  },
  "autoload": {
    "psr-4": {
      "CitrusLab\\Totp\\": "src/"
    },
    "files": [
      "src/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "CitrusLab\\TotpTests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration tests/phpunit.xml --coverage-text --testsuite \"Equit Totp Full Test Suite\""
  },
  "bin": [
    "tools/totp.php"
  ]
}
